{
  "name": "thumbshooter",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "server",
    "client"
  ],
  "engines": {
    "node": ">=24.13.0",
    "npm": ">=11.6.2"
  },
  "scripts": {
    "dev:client": "npm run dev --workspace client",
    "start:server": "npm run start --workspace server",
    "watch:server": "npm run watch:build --workspace server",
    "start:server:watch": "npm run start:watch --workspace server",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "check": "npm run typecheck && npm run build"
  },
  "devDependencies": {
    "@types/node": "25.5.2",
    "typescript": "6.0.2"
  }
}
