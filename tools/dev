#!/usr/bin/env bash

set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

cd "$repo_root"

pids=()

cleanup() {
  trap - EXIT INT TERM

  for pid in "${pids[@]:-}"; do
    kill "$pid" 2>/dev/null || true
  done

  wait 2>/dev/null || true
}

trap cleanup EXIT INT TERM

npm run dev:server &
pids+=($!)

npm run dev:client &
pids+=($!)

wait -n "${pids[@]}"
